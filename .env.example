# Firebase Configuration
# Get these values from Firebase Console: https://console.firebase.google.com/
# Project Settings > General > Your apps > SDK setup and configuration

# Firebase API Key (safe to expose client-side - protected by domain restrictions)
VITE_FIREBASE_API_KEY=your_api_key_here

# Firebase Auth Domain (format: your-project-id.firebaseapp.com)
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com

# Firebase Project ID
VITE_FIREBASE_PROJECT_ID=your_project_id

# Firebase Storage Bucket (format: your-project-id.appspot.com)
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com

# Firebase Messaging Sender ID (numeric)
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012

# Firebase App ID (format: 1:123456789012:web:abc123def456)
VITE_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# Firebase Measurement ID (optional - only needed if using Google Analytics)
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================================================
# Firebase App Check (reCAPTCHA v3)
# ============================================================================
# This is the reCAPTCHA v3 *site key* (public) configured via Firebase App Check.
# Do NOT put your reCAPTCHA *secret key* in the client.
VITE_FIREBASE_APPCHECK_RECAPTCHA_V3_SITE_KEY=your_recaptcha_v3_site_key_here

# Optional (dev only): set to true to use Firebase App Check debug tokens locally.
# When enabled, Firebase will print a debug token in the browser console. You must
# then register that token in Firebase Console → App Check → Apps.
VITE_FIREBASE_APPCHECK_DEBUG=false

# ============================================================================
# Base content source (SQLite -> Firestore cutover)
# ============================================================================
# Controls where the app reads its *base* content from.
# - sqlite: load from /public/content.db via sql.js (offline-first)
# - firestore: load from Firestore collections (requires rules + imported data)
#
# Default is sqlite for safety; set to firestore after running the migration script.
VITE_BASE_CONTENT_SOURCE=sqlite

# ============================================================================
# Development Mode (bypass authentication)
# ============================================================================
# Set to true to bypass Firebase authentication in development
# This creates a mock admin user (dev@localhost) for local testing
# WARNING: Only use in local development! Never set this in production!
# VITE_DEV_MODE_BYPASS_AUTH=true

# ============================================================================
# SETUP INSTRUCTIONS:
# ============================================================================
# 1. Copy this file to `.env` in the project root
# 2. Replace all placeholder values with your actual Firebase credentials
# 3. Never commit the `.env` file to version control (already in .gitignore)
#
# To get your Firebase credentials:
# 1. Go to https://console.firebase.google.com/
# 2. Select your project (or create a new one)
# 3. Click the gear icon > Project settings
# 4. Scroll to "Your apps" section
# 5. If no web app exists, click "Add app" and select the web platform (</>)
# 6. Copy the config values from the Firebase SDK snippet
#
# To enable Google OAuth:
# 1. In Firebase Console, go to Authentication > Sign-in method
# 2. Enable "Google" provider
# 3. Add authorized domains (localhost for dev, your production domain)
# 4. Configure OAuth consent screen in Google Cloud Console if prompted
# ============================================================================

# NOTE: These API keys are safe to expose in client-side code. Firebase uses
# domain restrictions and security rules to protect your data, not API key secrecy.
# However, keep the `.env` file gitignored to avoid accidentally committing
# sensitive project identifiers.
