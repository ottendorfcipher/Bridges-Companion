{
  "name": "bridge-companion",
  "version": "1.0.0",
  "description": "PWA for educational content management",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "db:create": "node scripts/createDb.js",
    "db:rebuild": "node scripts/buildDatabaseFromContent.cjs",
    "db:import-content": "node scripts/import-json-content.js",
    "db:import-layer2": "node scripts/import-layer2-reference-drawers.js",
    "db:rebuild-from-firestore": "node scripts/rebuild-content-db-from-firestore.js",
    "admin:init": "node scripts/setInitialAdmin.js",
    "versions:init": "node scripts/init-versions.js",
    "test": "vitest"
  },
  "dependencies": {
    "@tiptap/extension-color": "^3.14.0",
    "@tiptap/extension-link": "^3.14.0",
    "@tiptap/extension-text-align": "^3.14.0",
    "@tiptap/extension-text-style": "^3.14.0",
    "@tiptap/extension-underline": "^3.14.0",
    "@tiptap/react": "^3.14.0",
    "@tiptap/starter-kit": "^3.14.0",
    "feather-icons": "^4.29.2",
    "firebase": "^12.7.0",
    "firebase-admin": "^12.7.0",
    "marked": "^17.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "@types/marked": "^5.0.2",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/sql.js": "^1.4.9",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitejs/plugin-react": "^4.2.1",
    "better-sqlite3": "^12.5.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "sharp": "^0.34.5",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vite-plugin-pwa": "^0.17.4",
    "vitest": "^1.2.0",
    "workbox-window": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
